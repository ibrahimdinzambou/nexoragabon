[Unit]
Description=Nexora Drama Python API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/nexora/app/reelshort-api
Environment=PORT=5000
ExecStart=/opt/nexora/app/reelshort-api/.venv/bin/gunicorn --bind 127.0.0.1:5000 --workers 2 --timeout 120 reelshort:app
Restart=on-failure
RestartSec=5
User=nexora
Group=nexora

[Install]
WantedBy=multi-user.target
