[Unit]
Description=Nexora Anime API (Anime-Sama)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/nexora/anime-nexoraAPI
Environment=ANIME_SAMA_SITE_URL=https://anime-sama.to/
Environment=FLASK_HOST=127.0.0.1
Environment=PORT=5001
ExecStart=/opt/nexora/anime-nexoraAPI/.venv/bin/anime-sama-api
Restart=on-failure
RestartSec=5
User=nexora
Group=nexora
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
