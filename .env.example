# SMTP - LWS
MAIL_MAILER=smtp
MAIL_SCHEME=smtp
MAIL_HOST=mail96.lwspanel.com
MAIL_PORT=465
MAIL_USERNAME=replace-with-your-lws-mailbox
MAIL_PASSWORD=replace-with-your-lws-mailbox-password
MAIL_FROM_ADDRESS=replace-with-your-lws-mailbox
MAIL_FROM_NAME=Nexora
MAIL_SMTP_AUTH=true
MAIL_STARTTLS=false
MAIL_STARTTLS_REQUIRED=false
MAIL_SSL=true

# Domaine public / API
PUBLIC_SITE_URL=https://nexoragabon.com
PUBLIC_API_BASE_URL=https://nexora-api-production.up.railway.app
CORS_ALLOWED_ORIGIN_PATTERNS=https://nexoragabon.com,https://www.nexoragabon.com,https://*.vercel.app

# Super admin seed
SUPER_ADMIN_EMAIL=alexandredinzambou@gmail.com
SUPER_ADMIN_NAME=Alexandre Dinzambou
# Laissez vide pour ne pas reinitialiser un super admin existant.
SUPER_ADMIN_PASSWORD=

# Railway / PostgreSQL
# Sur Railway, ajoutez un service PostgreSQL puis referencez ses variables
# dans le service Spring Boot.
# SPRING_PROFILES_ACTIVE=postgres
# SPRING_DATASOURCE_URL=jdbc:postgresql://${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}
# SPRING_DATASOURCE_USERNAME=${{Postgres.PGUSER}}
# SPRING_DATASOURCE_PASSWORD=${{Postgres.PGPASSWORD}}

# Telegram - bot logs / alertes
TELEGRAM_ALERTS_ENABLED=true
TELEGRAM_ALERTS_BOT_TOKEN=replace-with-alerts-botfather-token
TELEGRAM_ALERTS_CHAT_ID=replace-with-logs-chat-id
TELEGRAM_IPTV_ALERTS_ENABLED=true
TELEGRAM_IPTV_ALERT_INTERVAL_MS=300000
TELEGRAM_IPTV_EXPIRY_ALERT_DAYS=7
TELEGRAM_IPTV_SATURATION_THRESHOLD_PERCENT=90

# Telegram - bot administration
TELEGRAM_ADMIN_ENABLED=false
TELEGRAM_ADMIN_BOT_TOKEN=replace-with-admin-botfather-token
TELEGRAM_ADMIN_CHAT_ID=replace-with-admin-chat-id
TELEGRAM_ADMIN_ALLOWED_CHAT_IDS=replace-with-admin-chat-id
TELEGRAM_ADMIN_READONLY_CHAT_IDS=
TELEGRAM_ADMIN_CHAT_ROLES=replace-with-admin-chat-id:SUPER_ADMIN
TELEGRAM_ADMIN_POLL_INTERVAL_MS=3000

# IPTV - cache, recherche et lecture
IPTV_CACHE_TTL=900
IPTV_M3U_CACHE_DIRECTORY=./data/m3u-cache
IPTV_M3U_CACHE_MAX_AGE_HOURS=168
IPTV_M3U_MAX_PLAYLIST_BYTES=134217728
IPTV_M3U_READ_TIMEOUT_SECONDS=180
IPTV_XTREAM_CACHE_DIRECTORY=./data/xtream-cache
IPTV_XTREAM_CACHE_MAX_AGE_HOURS=168
IPTV_XTREAM_TIMEOUT_SECONDS=45
IPTV_XTREAM_MAX_RESPONSE_BYTES=134217728
IPTV_PROXY_RANGE_CHUNK_BYTES=4194304
IPTV_PROXY_CONNECT_TIMEOUT_SECONDS=15
IPTV_PROXY_REQUEST_TIMEOUT_SECONDS=30
IPTV_PROXY_FIRST_BYTE_TIMEOUT_SECONDS=15
IPTV_HEALTH_DISABLE_AFTER_FAILURES=3
IPTV_VLC_PATH=
IPTV_VLC_STARTUP_TIMEOUT_SECONDS=45

# Community add-ons
ADDON_MAX_RESPONSE_BYTES=2097152
ADDON_CACHE_TTL_SECONDS=300
ADDON_ALLOW_PRIVATE_HOSTS=false
TORBOX_API_TOKEN=replace-with-your-torbox-api-token
TORBOX_API_BASE_URL=https://api.torbox.app
TORBOX_ALLOWED_DOWNLOAD_HOSTS=.torbox.app,.tb-cdn.io
TORBOX_MAX_WAIT_SECONDS=90
TORBOX_POLL_INTERVAL_MILLIS=2000

# Stremio Porn - endpoint Railway du service addons/stremio-porn
# Sur Railway, si le service add-on s'appelle stremio-porn:
# STREMIO_PORN_ADDON_URL=https://${{stremio-porn.RAILWAY_PUBLIC_DOMAIN}}/stremioget/stremio/v1
# Accepte aussi un domaine nu; Nexora ajoutera /stremioget/stremio/v1.
STREMIO_PORN_ADDON_URL=https://your-stremio-porn-service.up.railway.app/stremioget/stremio/v1
STREMIO_PORN_ALLOWED_STREAM_HOSTS=*

# Consumet - instance REST auto-hebergee
CONSUMET_ENABLED=false
CONSUMET_BASE_URL=https://your-consumet-instance.example
CONSUMET_MOVIE_PROVIDER=flixhq
CONSUMET_ANIME_PROVIDER=hianime
CONSUMET_MOVIE_SERVER=vidcloud
CONSUMET_ANIME_SERVER=vidstreaming
CONSUMET_ANIME_CATEGORY=sub
CONSUMET_SOURCE_MODE=auto
CONSUMET_META_PROVIDER=zoro
CONSUMET_EMBED_SOURCE=hd-2
CONSUMET_EMBED_PLAYER_URL=https://vidnest.fun
CONSUMET_OTHER_EMBED_PLAYER_URL=https://animeplay.cfd/stream/ani
CONSUMET_TIMEOUT_SECONDS=20
CONSUMET_MAX_RESPONSE_BYTES=2097152
# Domaines HLS supplementaires autorises si les playlists pointent vers des CDN externes
CONSUMET_ALLOWED_STREAM_HOSTS=

# TMDB - metadonnees films, series et images
TMDB_API_KEY=replace-with-your-tmdb-v3-api-key
TMDB_READ_ACCESS_TOKEN=replace-with-your-tmdb-read-access-token
TMDB_API_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
TMDB_LANGUAGE=fr-FR
TMDB_REGION=FR
TMDB_INCLUDE_ADULT=false
TMDB_TIMEOUT_SECONDS=12
TMDB_MAX_RESPONSE_BYTES=2097152
